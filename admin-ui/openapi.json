{
  "openapi": "3.1.0",
  "info": {
    "title": "arctern",
    "description": "ZFS replication daemon HTTP API",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/config": {
      "get": {
        "tags": [
          "config"
        ],
        "operationId": "get_config",
        "responses": {
          "200": {
            "description": "The TOML file currently loaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigView"
                }
              }
            }
          },
          "500": {
            "description": "Config file unreadable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets": {
      "get": {
        "tags": [
          "datasets"
        ],
        "summary": "List datasets reachable through the daemon's shared `CommandRunner`\n(`AppState::runner`). RealRunner in production; SshCommandRunner\nonly when `PALIMPSEST_SSH_TARGET` is set for dev/test.",
        "operationId": "list_datasets",
        "responses": {
          "200": {
            "description": "All datasets visible to the daemon's ZFS runner",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DatasetSummary"
                  }
                }
              }
            }
          },
          "500": {
            "description": "ZFS returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{name}/snapshots": {
      "get": {
        "tags": [
          "snapshots"
        ],
        "summary": "List snapshots of `{name}` (one dataset, non-recursive). Properties\n`creation` and `used` come along so the UI can render age + size.",
        "operationId": "list_snapshots",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Parent dataset (URL-encode `/` as %2F)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Filter to snapshots whose tag (after the `@`) starts with this\nprefix. Useful to keep zrepl_-style snapshots out of the noise\nwhen manual snapshots also exist on the dataset.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshots of the dataset, oldest first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DatasetSummary"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "ZFS returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "snapshots"
        ],
        "summary": "Create a snapshot of `{name}` named `req.snapshot_name`.\n`palimpsest::ZfsError::SnapshotExists` maps to 409 — the caller\ndecides whether already-exists is fatal.",
        "operationId": "create_snapshot",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Parent dataset (URL-encode `/` as %2F)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSnapshotRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Snapshot created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetSummary"
                }
              }
            }
          },
          "404": {
            "description": "Parent dataset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "409": {
            "description": "Snapshot already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "ZFS returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{name}/snapshots/{snapshot}/destroy": {
      "post": {
        "tags": [
          "snapshots"
        ],
        "summary": "Destroy snapshot `{name}@{snapshot}`. Path-segment escaping: the\ndataset goes URL-encoded (`%2F` for `/`); the snapshot tag is the\npart after the `@`.",
        "operationId": "destroy_snapshot",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Parent dataset (URL-encode `/` as %2F)",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "snapshot",
            "in": "path",
            "description": "Snapshot tag (the part after `@`)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Snapshot destroyed"
          },
          "404": {
            "description": "Snapshot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "409": {
            "description": "Snapshot has a hold",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "ZFS returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/events": {
      "get": {
        "tags": [
          "events"
        ],
        "summary": "Subscribe to the daemon's log-event broadcast and yield each as an\nSSE frame. Backlog replay is intentionally out of scope for v1 — the\nreceiver-side SubscribeEvents handler is built around polling\nlog_events directly. UI clients that want history hit a\nfuture `/api/v1/events?since=…` endpoint or the SQLite directly.",
        "operationId": "stream_events",
        "responses": {
          "200": {
            "description": "SSE stream of LogEvent JSON frames"
          }
        }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "tags": [
          "jobs"
        ],
        "operationId": "list_jobs",
        "responses": {
          "200": {
            "description": "Per-job status snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobStatus"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{name}/runs": {
      "get": {
        "tags": [
          "jobs"
        ],
        "operationId": "list_runs",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Job name as declared in arctern.toml",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Unix-second cutoff; rows with `started_at >= since` are returned.",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of rows to return. Defaults to 100, capped at 1000.",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent job runs, newest first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobRun"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{name}/wakeup": {
      "post": {
        "tags": [
          "jobs"
        ],
        "operationId": "wakeup",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Job name as declared in arctern.toml",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Job's cycle loop was woken up"
          },
          "404": {
            "description": "No job with that name is registered"
          }
        }
      }
    },
    "/api/v1/peers": {
      "get": {
        "tags": [
          "peers"
        ],
        "operationId": "list_peers",
        "responses": {
          "200": {
            "description": "Configured peers with reachability",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PeerSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/events": {
      "get": {
        "tags": [
          "peers"
        ],
        "summary": "`GET /api/v1/peers/{peer}/events` — proxied SSE. Sends\nSubscribeEvents to the peer's control channel and yields each\npushed Event frame as an SSE frame.",
        "operationId": "stream_peer_events",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE stream of LogEvent JSON frames from the peer"
          },
          "404": {
            "description": "No such peer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/jobs": {
      "get": {
        "tags": [
          "peers"
        ],
        "operationId": "list_peer_jobs",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Per-job status snapshot from the peer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/JobStatus"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No such peer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/jobs/{name}": {
      "get": {
        "tags": [
          "peers"
        ],
        "operationId": "get_peer_job",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "path",
            "description": "Job name on the peer",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status for one job on the peer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobStatus"
                }
              }
            }
          },
          "404": {
            "description": "No such peer / job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/jobs/{name}/wakeup": {
      "post": {
        "tags": [
          "peers"
        ],
        "operationId": "wakeup_peer_job",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "path",
            "description": "Job name on the peer",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Wakeup delivered"
          },
          "404": {
            "description": "No such peer / job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/snapshots": {
      "get": {
        "tags": [
          "peers"
        ],
        "operationId": "list_peer_snapshots",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dataset",
            "in": "query",
            "description": "Dataset on the peer",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefix_regex",
            "in": "query",
            "description": "Optional name filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshots on the peer for the dataset",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PeerSnapshotEntry"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No such peer / dataset",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/peers/{peer}/snapshots/{name}/destroy": {
      "post": {
        "tags": [
          "peers"
        ],
        "operationId": "destroy_peer_snapshot",
        "parameters": [
          {
            "name": "peer",
            "in": "path",
            "description": "Peer name from [[peers]]",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "path",
            "description": "Snapshot name (URL-encode @ and /)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Snapshot destroyed on the peer"
          },
          "403": {
            "description": "Not allowed under the peer's ACL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "No such peer / snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "503": {
            "description": "Peer not currently connected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pools": {
      "get": {
        "tags": [
          "pools"
        ],
        "operationId": "list_pools",
        "responses": {
          "200": {
            "description": "All imported pools with health + capacity",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PoolSummary"
                  }
                }
              }
            }
          },
          "500": {
            "description": "zpool returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pools/{name}": {
      "get": {
        "tags": [
          "pools"
        ],
        "operationId": "get_pool",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Pool name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full status with vdev tree + scrub progress",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PoolStatus"
                }
              }
            }
          },
          "404": {
            "description": "No imported pool with that name",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "zpool returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/pools/{name}/scrub": {
      "post": {
        "tags": [
          "pools"
        ],
        "operationId": "pool_scrub",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Pool name",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrubRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "zpool scrub accepted the action"
          },
          "400": {
            "description": "Unknown action",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "zpool returned an error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorBody"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiErrorBody": {
        "type": "object",
        "description": "Body shape for `4xx`/`5xx` responses from the daemon. `error` is a\nshort machine-readable category (`spawn`, `dataset_not_found`, …);\n`message` is a human-readable description.",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ConfigView": {
        "type": "object",
        "description": "Body of `GET /api/v1/config` — the on-disk TOML the daemon was\nstarted with, plus its absolute path. Read-only: there is no\nwrite-back endpoint, so this is a faithful echo of what's loaded,\nnot what the daemon may have parsed (you can spot drift by\ncomparing to the other endpoints).",
        "required": [
          "path",
          "content_toml"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "content_toml": {
            "type": "string"
          }
        }
      },
      "CreateSnapshotRequest": {
        "type": "object",
        "description": "Request body for `POST /api/v1/datasets/{name}/snapshots`. The path\nsegment carries the parent dataset; this struct carries everything\nelse. `recursive` and `properties` default so a minimal client can\npost `{\"snapshot_name\":\"…\"}` and get the common case.",
        "required": [
          "snapshot_name"
        ],
        "properties": {
          "snapshot_name": {
            "type": "string"
          },
          "recursive": {
            "type": "boolean"
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          }
        }
      },
      "DatasetSummary": {
        "type": "object",
        "description": "Slim projection of [`palimpsest::ZfsListEntry`] suitable for HTTP +\nOpenAPI. Native ZFS properties carry typed data (bytes, bool, …) but\n`BTreeMap<String, String>` serializes more cleanly through utoipa;\nconsumers parse property values as needed.",
        "required": [
          "name",
          "dataset_type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "dataset_type": {
            "type": "string",
            "description": "`\"filesystem\" | \"volume\" | \"snapshot\" | \"bookmark\"` — lowercase\nto match `zfs(8)`'s output and avoid leaking palimpsest's enum repr."
          },
          "properties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          }
        }
      },
      "JobRun": {
        "type": "object",
        "description": "One row of `job_runs` returned by `GET /api/v1/jobs/{name}/runs`.\n`started_at` / `finished_at` are unix seconds; `bytes_sent` is set\nonly by push jobs that finished cleanly.",
        "required": [
          "started_at",
          "status"
        ],
        "properties": {
          "started_at": {
            "type": "integer",
            "format": "int64"
          },
          "finished_at": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "status": {
            "type": "string"
          },
          "error_message": {
            "type": [
              "string",
              "null"
            ]
          },
          "bytes_sent": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          }
        }
      },
      "JobStatus": {
        "type": "object",
        "description": "One entry in the response of `GET /api/v1/jobs`. RFC3339 timestamps\nare nullable: `last_run` is null until the job has completed at\nleast one cycle; `next_run` is set as soon as the loop knows when\nit will fire next; `last_error` is null when the most recent cycle\nfinished cleanly.",
        "required": [
          "name",
          "kind"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "last_run": {
            "type": [
              "string",
              "null"
            ]
          },
          "next_run": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_error": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "LogEvent": {
        "type": "object",
        "description": "One row in `GET /api/v1/events` (and the proxied\n`GET /api/v1/peers/{peer}/events`). Mirrors\n`arctern_transport::EventWire` but lives in the public API surface\nso clients don't pull in the transport crate.",
        "required": [
          "id",
          "timestamp",
          "level",
          "message"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "Unix seconds."
          },
          "level": {
            "type": "string"
          },
          "job_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "PeerReachability": {
        "oneOf": [
          {
            "type": "object",
            "description": "SSH session is up and the control channel is responding.",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "connected"
                ]
              }
            }
          },
          {
            "type": "object",
            "description": "Background task is between reconnect attempts.",
            "required": [
              "since",
              "kind"
            ],
            "properties": {
              "since": {
                "type": "string",
                "description": "RFC3339 timestamp the link first went down."
              },
              "kind": {
                "type": "string",
                "enum": [
                  "reconnecting"
                ]
              }
            }
          },
          {
            "type": "object",
            "description": "Last connect attempt failed; the loop is sleeping before retrying.",
            "required": [
              "since",
              "last_error",
              "kind"
            ],
            "properties": {
              "since": {
                "type": "string",
                "description": "RFC3339 timestamp the link first went down (or last failed)."
              },
              "last_error": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "failed"
                ]
              }
            }
          }
        ],
        "description": "Reachability classification for one configured peer. The daemon\nupdates this from its background reconnect loop; the UI surfaces\nit in the Peers tab."
      },
      "PeerSnapshotEntry": {
        "type": "object",
        "description": "One snapshot returned by `GET /api/v1/peers/{peer}/snapshots`.",
        "required": [
          "name",
          "guid",
          "createtxg"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "guid": {
            "type": "string",
            "description": "ZFS GUID, serialized as a u64 string to stay safe across\nJSON parsers that downgrade large integers to f64."
          },
          "createtxg": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "PeerSummary": {
        "type": "object",
        "description": "One row in `GET /api/v1/peers`.",
        "required": [
          "name",
          "ssh_target",
          "reachability"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ssh_target": {
            "type": "string"
          },
          "reachability": {
            "$ref": "#/components/schemas/PeerReachability"
          }
        }
      },
      "PoolStatus": {
        "type": "object",
        "description": "`GET /api/v1/pools/{name}` — full status: scrub + recursive vdev tree.",
        "required": [
          "name",
          "state",
          "error_count",
          "pool_guid",
          "txg",
          "vdevs"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "error_count": {
            "type": "string"
          },
          "pool_guid": {
            "type": "string"
          },
          "txg": {
            "type": "string"
          },
          "scan": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ScanSummary"
              }
            ]
          },
          "vdevs": {
            "type": "array",
            "items": {},
            "description": "Tree of vdevs. Schema is opaque (`Vec<serde_json::Value>`) here\nbecause the underlying `VdevNode` is recursive and utoipa can't\nauto-inline it — see the comment on `VdevNode`. The wire format\nis still a real `Vec<VdevNode>`."
          }
        }
      },
      "PoolSummary": {
        "type": "object",
        "description": "One pool's slot in `GET /api/v1/pools`. Numeric fields are\n`zpool`-formatted strings (e.g. `\"608G\"`, `\"1.48T\"`) rather than\nraw bytes because that's what `zpool` emits and round-tripping\nthrough bytes risks rounding mismatches in the UI.",
        "required": [
          "name",
          "state",
          "error_count",
          "alloc_space",
          "total_space"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "description": "`\"ONLINE\"`, `\"DEGRADED\"`, `\"FAULTED\"`, …"
          },
          "error_count": {
            "type": "string",
            "description": "Aggregate error count across all vdevs."
          },
          "alloc_space": {
            "type": "string"
          },
          "total_space": {
            "type": "string"
          },
          "scan": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ScanSummary",
                "description": "Most recent scrub/resilver status if zpool reports one."
              }
            ]
          }
        }
      },
      "ScanSummary": {
        "type": "object",
        "required": [
          "function",
          "state"
        ],
        "properties": {
          "function": {
            "type": "string",
            "description": "`\"SCRUB\"`, `\"RESILVER\"`, `\"NONE\"`."
          },
          "state": {
            "type": "string",
            "description": "`\"SCANNING\"`, `\"FINISHED\"`, `\"CANCELED\"`."
          },
          "start_time": {
            "type": [
              "string",
              "null"
            ]
          },
          "end_time": {
            "type": [
              "string",
              "null"
            ]
          },
          "to_examine": {
            "type": [
              "string",
              "null"
            ]
          },
          "examined": {
            "type": [
              "string",
              "null"
            ]
          },
          "errors": {
            "type": [
              "string",
              "null"
            ]
          },
          "pass_start": {
            "type": [
              "string",
              "null"
            ]
          },
          "scrub_pause": {
            "type": [
              "string",
              "null"
            ]
          },
          "issued": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ScrubRequest": {
        "type": "object",
        "description": "Body of `POST /api/v1/pools/{name}/scrub`.",
        "required": [
          "action"
        ],
        "properties": {
          "action": {
            "type": "string",
            "description": "`\"start\"`, `\"pause\"`, `\"resume\"`, or `\"stop\"`."
          }
        }
      }
    }
  }
}
